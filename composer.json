{
	"name": "automattic/newspack-circ-print-integration",
	"version": "1.0.0",
	"description": "Plugin to integrate Newspack with print circulation systems",
	"type": "wordpress-plugin",
	"require": {
		"composer/installers": "^2.3",
		"deliciousbrains/wp-background-processing": "^1.4"
	},
	"require-dev": {
		"automattic/vipwpcs": "^3.0",
		"wp-coding-standards/wpcs": "^3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "*",
		"phpcompatibility/phpcompatibility-wp": "*",
		"squizlabs/php_codesniffer": "3.*",
		"coenjacobs/mozart": "^0.7.1"
	},
	"license": "GPL-3.0",
	"autoload": {
		"classmap": [
			"./includes"
		]
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"extra": {
		"mozart": {
			"dep_namespace": "Newspack\\PrintCirculationIntegration\\Dependencies\\",
			"dep_directory": "/includes/Dependencies/",
			"classmap_directory": "/includes/vendor/dependencies/",
			"classmap_prefix": "Newspack_Print_Circ_Integration_",
			"packages": [
				"deliciousbrains/wp-background-processing"
			]
		}
	},
	"scripts": {
		"post-install-cmd": [
			"\"vendor/bin/mozart\" compose",
			"composer dump-autoload"
		],
		"post-update-cmd": [
			"\"vendor/bin/mozart\" compose",
			"composer dump-autoload"
		]
	}
}
